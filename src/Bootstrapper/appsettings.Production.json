{
  "ApplicationInfo": {
    "ApplicationIdentifier": "owlmapper-prod",
    "ApplicationName": "OwlMapper Production"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning"
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "PostgreSQL": "",
    "RabbitMQ": ""
  },
  "HealthChecks": {
    "EnablePostgreSQL": true,
    "EnableRabbitMQ": true
  }
}
